<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Menace.ModManager.Views.MainWindow"
        Width="980" Height="680"
        Title="Menace Mod Manager">
  <Grid DragDrop.AllowDrop="True">

    <!-- Main content (disabled while a long operation runs) -->
    <DockPanel Margin="12" IsEnabled="{Binding NotBusy}">

      <!-- Status + refresh -->
      <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
        <Button DockPanel.Dock="Right" Content="Refresh" Click="OnRefreshClick" />
        <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
      </DockPanel>

      <!-- Error banner -->
      <Border DockPanel.Dock="Top" IsVisible="{Binding HasError}"
              Background="#C0392B" CornerRadius="4" Padding="10,6" Margin="0,0,0,10">
        <DockPanel>
          <Button DockPanel.Dock="Right" Content="✕" Click="OnDismissErrorClick"
                  Background="Transparent" BorderThickness="0" Foreground="White" Padding="8,0" />
          <TextBlock Text="{Binding ErrorMessage}" Foreground="White"
                     TextWrapping="Wrap" VerticalAlignment="Center" />
        </DockPanel>
      </Border>

      <!-- Loaders -->
      <Border DockPanel.Dock="Top" Margin="0,0,0,12" Padding="12" CornerRadius="6"
              BorderThickness="1" BorderBrush="#33808080">
        <StackPanel Spacing="2">
          <TextBlock Text="LOADERS" FontSize="11" FontWeight="Bold" Opacity="0.55" Margin="0,0,0,6" />
          <Grid ColumnDefinitions="150,*,Auto" RowDefinitions="Auto,Auto,Auto">

            <TextBlock Grid.Row="0" Grid.Column="0" Text="MelonLoader" VerticalAlignment="Center" />
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Text="{Binding MelonLoaderStatus}" Opacity="0.6" VerticalAlignment="Center" />
              <ComboBox ItemsSource="{Binding MelonLoaderVersions}" SelectedItem="{Binding SelectedMelonLoaderVersion}" MinWidth="130" />
            </StackPanel>
            <Button Grid.Row="0" Grid.Column="2" Content="Get" Click="OnInstallMelonLoaderClick" IsEnabled="{Binding CanGetMelonLoader}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Modpack Loader" VerticalAlignment="Center" Margin="0,8,0,0" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ModpackLoaderStatus}" Opacity="0.6" VerticalAlignment="Center" Margin="0,8,0,0" />
            <Button Grid.Row="1" Grid.Column="2" Content="Install / Update" Click="OnInstallModpackLoaderClick" Margin="0,8,0,0" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Jiangyu Loader" VerticalAlignment="Center" Margin="0,8,0,0" />
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,8,0,0">
              <TextBlock Text="{Binding JiangyuLoaderStatus}" Opacity="0.6" VerticalAlignment="Center" />
              <ComboBox ItemsSource="{Binding JiangyuVersions}" SelectedItem="{Binding SelectedJiangyuVersion}" MinWidth="130" />
            </StackPanel>
            <Button Grid.Row="2" Grid.Column="2" Content="Get" Click="OnGetJiangyuClick" Margin="0,8,0,0" IsEnabled="{Binding CanGetJiangyu}" />

          </Grid>
        </StackPanel>
      </Border>

      <!-- Mod actions -->
      <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="0,10,0,0">
        <Button Content="Add mod…" Click="OnAddModClick" />
        <Button Content="Deploy source…" Click="OnDeploySourceClick" />
        <Button Content="Uninstall selected" Click="OnUninstallClick" />
      </StackPanel>

      <!-- Column header -->
      <Grid DockPanel.Dock="Top" ColumnDefinitions="60,110,*,150,130" Margin="4,0,4,4">
        <TextBlock Grid.Column="0" Text="On" Opacity="0.6" />
        <TextBlock Grid.Column="1" Text="Kind" Opacity="0.6" />
        <TextBlock Grid.Column="2" Text="Name" Opacity="0.6" />
        <TextBlock Grid.Column="3" Text="Version" Opacity="0.6" />
        <TextBlock Grid.Column="4" Text="Author" Opacity="0.6" />
      </Grid>

      <!-- Mod list -->
      <ListBox ItemsSource="{Binding Mods}" SelectedItem="{Binding Selected}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="60,110,*,150,130">
              <CheckBox Grid.Column="0"
                        IsChecked="{Binding IsEnabled, Mode=OneWay}"
                        IsEnabled="{Binding CanToggle}"
                        Click="OnToggleClick" />
              <TextBlock Grid.Column="1" Text="{Binding Kind}" VerticalAlignment="Center" />
              <TextBlock Grid.Column="2" Text="{Binding DisplayName}" VerticalAlignment="Center" />
              <TextBlock Grid.Column="3" Text="{Binding VersionDisplay}" VerticalAlignment="Center" />
              <TextBlock Grid.Column="4" Text="{Binding Author}" VerticalAlignment="Center" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

    </DockPanel>

    <!-- Busy overlay -->
    <Border IsVisible="{Binding IsBusy}" Background="#99000000">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
        <ProgressBar IsIndeterminate="True" Width="240" />
        <TextBlock Text="{Binding Status}" Foreground="White" HorizontalAlignment="Center" />
      </StackPanel>
    </Border>

  </Grid>
</Window>
